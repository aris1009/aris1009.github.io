<article class="prose dark:prose-invert mx-auto max-w-3xl px-4 py-10">
  <h1 class="text-4xl font-bold mb-4">Diceware Passphrase Generator</h1>
  <p class="text-zinc-600 dark:text-zinc-300">
    Everything runs in your browser. No passphrase, seed, or request leaves this page.
    The word list is the
    <a href="https://www.eff.org/dice" rel="noopener">EFF large wordlist</a>
    (7,776 words), bundled with this site so you can verify exactly what you ran.
  </p>

  <section id="diceware-app"
           class="not-prose my-8 rounded-xl border border-zinc-200 dark:border-zinc-700 p-6 bg-white dark:bg-zinc-900 shadow-sm"
           data-wordlist-url="{{ wordlists.eff_large_v1.url }}"
           data-wordlist-sha256="{{ wordlists.eff_large_v1.sha256 }}">

    <div id="diceware-status" class="mb-4 text-sm text-zinc-500 dark:text-zinc-400" role="status" aria-live="polite">
      Loading wordlist…
    </div>

    <div class="grid gap-4 md:grid-cols-3 mb-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium">Word count</span>
        <input id="dw-count" type="number" min="4" max="12" value="6"
               class="rounded border border-zinc-300 dark:border-zinc-600 bg-transparent px-3 py-2" />
      </label>

      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium">Separator</span>
        <select id="dw-separator" class="rounded border border-zinc-300 dark:border-zinc-600 bg-transparent px-3 py-2">
          <option value=" ">space</option>
          <option value="-" selected>dash</option>
          <option value=".">dot</option>
        </select>
      </label>

      <label class="flex items-end gap-2 text-sm">
        <input id="dw-capitalize" type="checkbox" class="h-4 w-4" />
        <span class="font-medium">Capitalize each word</span>
      </label>
    </div>

    <div class="flex gap-2 mb-4">
      <button id="dw-generate" type="button" disabled
              class="rounded bg-sky-600 hover:bg-sky-700 disabled:opacity-50 text-white px-4 py-2 font-medium">
        Generate
      </button>
      <button id="dw-copy" type="button" disabled
              class="rounded border border-zinc-300 dark:border-zinc-600 px-4 py-2 font-medium">
        Copy
      </button>
