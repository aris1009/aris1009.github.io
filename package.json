{
  "type": "module",
  "scripts": {
    "dev": "run-p dev:*",
    "build": "NODE_ENV=production run-s clean detect-languages verify-wordlists build:prism build:mermaid favicons eleventy css:website",
    "build:prod": "NODE_ENV=production run-s clean detect-languages verify-wordlists build:prism build:mermaid favicons eleventy css:website",
    "detect-languages": "node scripts/detect-prism-languages.js",
    "verify-wordlists": "node scripts/verify-wordlists.js",
    "build:prism": "node scripts/build-prism.js",
    "build:mermaid": "node scripts/build-mermaid.js",
    "favicons": "node scripts/generate-favicons.js",
    "og:regen": "node scripts/generate-og-images.js",
    "clean": "rimraf _site",
    "css:website": "npx tailwindcss -i src/_tailwindCSS/raw-website.css -o _site/css/style.css --minify --postcss",
    "eleventy": "eleventy",
    "dev:css": "npx tailwindcss -i src/_tailwindCSS/raw-website.css -o _site/css/style.css --watch --minify",
    "dev:11ty": "eleventy --serve --watch",
    "start": "npm run dev",
    "new-post": "node scripts/generate-blog-post.js",
    "test": "CI=true vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "links": "node scripts/process-links.js",
    "image-perf": "node scripts/measure-image-performance.js",
    "bundle:check": "du -h _site/css/style.css",
    "lint:css": "stylelint 'src/_tailwindCSS/**/*.css'",
    "analyze:css": "node scripts/analyze-css.js",
    "prepare": "husky"
  },
  "name": "blog",
  "version": "1.0.0",
  "description": "AI & Security Blog",
  "main": "index.js",
  "keywords": [
    "blog",
    "security",
    "11ty",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.2",
    "@axe-core/playwright": "^4.11.2",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@html-to/text-cli": "^0.5.4",
    "@playwright/test": "^1.59.1",
    "@projectwallace/css-analyzer": "^9.7.0",
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "eleventy-plugin-reading-time": "^0.0.1",
    "html-minifier": "^4.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "mermaid": "^11.11.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.12",
    "postcss-cli": "^11.0.1",
    "prismjs": "^1.30.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "sharp": "^0.34.5",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@11ty/eleventy-navigation": "^1.0.5",
    "eleventy-plugin-i18n": "^0.1.3",
    "eleventy-plugin-toc": "^1.1.5"
  },
  "bundleSizeLimit": {
    "css": 90000
  }
}
